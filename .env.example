# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=

# Optional: Socrata app token for higher rate limits
# Register at https://data.cityofchicago.org/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# Path to cloned Socrata MCP server (for MCP mode)
SOCRATA_MCP_PATH=../socrata-mcp-server

# Set to "true" to use the Python MCP server instead of direct TypeScript tools
USE_MCP=false
